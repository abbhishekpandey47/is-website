{
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path*.{jpg,jpeg,png,gif,webp,svg,ico}",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/fonts/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "src/app/api/geo-audit/route.js": {
      "maxDuration": 300
    },
    "src/pages/api/reddit/cron-check-status.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/reddit/cron-check-status",
      "schedule": "0 12 * * *"
    }
  ]
}